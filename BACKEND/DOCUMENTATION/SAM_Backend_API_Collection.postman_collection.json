{
  "info": {
    "name": "SAM Backend API",
    "description": "Complete API collection for SAM (Salon Management) Backend - 140 APIs\n\n⚠️ ACCESS CONTROL NOTES:\n- SUPER_ADMIN: Full access to all APIs\n- ADMIN: Salon-level access (cannot access SUPER_ADMIN endpoints)\n- STAFF: Limited salon-level access\n- CUSTOMER: Self-service only (own profile, appointments, invoices)\n- PUBLIC: Limited endpoints (services, packages, staff list, salon info, registration)\n\nLast Updated: 2026-03-27",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/Sam-Backend/BACKEND/public/index.php/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "salon_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 AUTH",
      "item": [
        {
          "name": "Super Admin Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"super@gmail.com\",\n  \"password\": \"123456\",\n  \"login_type\": \"SUPER_ADMIN\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["if (pm.response.code === 200) {",
                "    var jsonData = pm.response.json();",
                "    pm.environment.set('access_token', jsonData.data.access_token);",
                "    pm.environment.set('refresh_token', jsonData.data.refresh_token);",
                "}"]
            }
          }]
        },
